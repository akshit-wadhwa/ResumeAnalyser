<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.resumeanalyser.frontend.controller.ComparisonController"
            xmlns:fx="http://javafx.com/fxml" fx:id="rootPane" styleClass="root">
    <top>
        <VBox spacing="16" styleClass="panel" BorderPane.alignment="CENTER">
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label text="Resume Comparison Results" styleClass="title" HBox.hgrow="ALWAYS" />
                <Button text="← Back to Dashboard" onAction="#onBackToDashboard" styleClass="secondary" />
            </HBox>
            
            <Label fx:id="jobTitleLabel" text="Analyzing resumes for job requirements" styleClass="section-title" />
        </VBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" BorderPane.alignment="CENTER" style="-fx-background: transparent; -fx-border-width: 0;">
            <VBox fx:id="comparisonContainer" spacing="16" style="-fx-padding: 8;">
                <!-- Resume cards will be populated here dynamically -->
            </VBox>
        </ScrollPane>
    </center>
    
    <bottom>
        <HBox spacing="12" styleClass="panel" BorderPane.alignment="CENTER" style="-fx-padding: 16;">
            <Button text="⟲ New Comparison" onAction="#onBackToDashboard" styleClass="accent" HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>
    
    <padding>
        <Insets top="16" right="16" bottom="16" left="16" />
    </padding>
</BorderPane>

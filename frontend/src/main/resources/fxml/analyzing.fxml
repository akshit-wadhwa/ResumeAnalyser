<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListCell?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<StackPane fx:controller="com.resumeanalyser.frontend.controller.AnalyzingController"
           xmlns:fx="http://javafx.com/fxml" styleClass="root">
    <VBox alignment="CENTER" spacing="20" styleClass="card" maxWidth="500">
        <Label text="Resume Analysis in Progress" styleClass="title" />
        <Label text="Processing your resume against the job description..." styleClass="subtitle" />
        
        <VBox spacing="12" alignment="CENTER">
            <ProgressIndicator fx:id="progressIndicator" prefWidth="100" prefHeight="100" />
            <ProgressBar fx:id="progressBar" prefWidth="300" prefHeight="8" />
        </VBox>
        
        <VBox spacing="8">
            <Label text="Processing Steps" styleClass="section-title" />
            <ListView fx:id="progressList" prefHeight="150" />
        </VBox>
        
        <Label fx:id="statusLabel" styleClass="hint" text="Initializing analysis..." wrapText="true" />
        <Label fx:id="timeLabel" styleClass="hint" />
    </VBox>
    <padding>
        <Insets top="40" right="40" bottom="40" left="40" />
    </padding>
</StackPane>
